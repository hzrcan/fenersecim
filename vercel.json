{
  "redirects": [
    {
      "source": "/uye-topluluk",
      "destination": "/kongre-uyesi-on-kayit",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
